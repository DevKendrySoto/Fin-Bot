# Database
DATABASE_URL=postgresql://finbot:finbot_password@localhost:5432/finbot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_PORT=3000
API_HOST=localhost
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Webhook (Production)
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_key

# Bot Configuration
TELEGRAM_POLLING_INTERVAL=1000
TELEGRAM_TIMEOUT=30

# Default Settings
DEFAULT_CURRENCY=RD$
DEFAULT_TIMEZONE=America/Santo_Domingo

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Notifications
NOTIFICATION_ENABLED=true
NOTIFICATION_QUEUE_ENABLED=true

# Caching
CACHE_TTL=3600
CACHE_ENABLED=true

# Email (Future)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-password
MAIL_FROM=noreply@finbot.com
